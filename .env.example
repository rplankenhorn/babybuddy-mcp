# Required: URL of your babybuddy instance
# Examples:
#   http://localhost:8000          (local install)
#   http://babybuddy:8000          (Docker service name on shared network)
#   https://babybuddy.example.com  (external URL)
BABYBUDDY_URL=http://localhost:8000

# Required: API token from babybuddy web UI
# Go to Settings (top-right menu) > API Key, then copy the token
BABYBUDDY_TOKEN=your-api-token-here

# MCP server transport: "http" for Docker/network clients, "stdio" for Claude Desktop
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Optional tuning
REQUEST_TIMEOUT=30.0
DEFAULT_PAGE_SIZE=100
